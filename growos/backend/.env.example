NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://growos:growos_dev@localhost:5432/growos

# MQTT (local Guardian or cloud broker)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Auth
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Guardian discovery (optional — if cloud bridges to local hub)
GUARDIAN_LOCAL_IP=
GUARDIAN_API_PORT=8080

# Logging
LOG_LEVEL=info

# Client URL for CORS
CLIENT_URL=http://localhost:5173
